{% extends "layout.njk" %}

{% block title %}Accept invitation — Tasklist{% endblock %}

{% block content %}
<div class="auth-page">
  <h1>You're invited</h1>
  <p>You've been invited to join <strong>{{ inv.list_name }}</strong>.</p>

  {% if user %}
    <p>Accepting as <strong>{{ user.username }}</strong>.</p>
    <form method="POST" action="/invitations/{{ inv.token }}">
      <button class="btn btn-primary">Accept invitation</button>
    </form>
  {% else %}
    <p>Sign in with GitHub to accept.</p>
    <a href="/auth/github" class="btn btn-github">Sign in with GitHub</a>
  {% endif %}
</div>
{% endblock %}
