<form class="new-board-form"
      hx-post="/boards"
      hx-target="#board-grid"
      hx-swap="afterbegin"
      hx-on::after-request="if(event.detail.successful){ this.closest('#new-board-form').innerHTML='' }">
  <input type="text"
         name="name"
         placeholder="Board name"
         class="input-board-name"
         required
         autofocus>
  <div class="form-actions">
    <button type="submit" class="btn btn-primary">Create</button>
    <button type="button"
            class="btn btn-secondary"
            onclick="document.getElementById('new-board-form').innerHTML=''">Cancel</button>
  </div>
</form>
