<form class="new-board-form"
      hx-post="/boards"
      hx-target="#board-grid"
      hx-swap="afterbegin">
  <input type="text"
         name="name"
         placeholder="Board name"
         class="input-board-name"
         required
         autofocus>
  <div class="form-actions">
    <button type="submit" class="btn btn-primary">Create</button>
    <button type="button"
            class="btn btn-secondary"
            data-clear-target="new-board-form">Cancel</button>
  </div>
</form>
