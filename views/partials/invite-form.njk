<div id="invite-area">
  <form hx-post="/boards/{{ boardId }}/invite"
        hx-target="#invite-area"
        hx-swap="innerHTML">
    <label>
      Email address
      <input type="email"
             name="email"
             placeholder="colleague@example.com"
             required
             autofocus>
    </label>
    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Send invite</button>
      <button type="button"
              class="btn btn-secondary"
              hx-get="/boards/{{ boardId }}/invite-cancel"
              hx-target="#invite-area"
              hx-swap="innerHTML">Cancel</button>
    </div>
  </form>
</div>
