<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}Taskboard{% endblock %}</title>
  <link rel="stylesheet" href="/style.css">
  <script src="https://unpkg.com/htmx.org@2.0.4" integrity="sha384-HGfztofotfshcF7+8n44JQL2oJmowVChPTg48S+jvZoztPfvwD79OC/LTtG6dMp+" crossorigin="anonymous"></script>
  <script src="https://unpkg.com/htmx-ext-sse@2.2.2/sse.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.6/Sortable.min.js"></script>
</head>
<body>
  <header class="site-header">
    <a href="/" class="site-logo">Taskboard</a>
    {% if user %}
    <nav class="site-nav">
      <img src="{{ user.avatar_url }}" alt="{{ user.username }}" class="avatar" width="32" height="32">
      <span class="username">{{ user.username }}</span>
      <form method="POST" action="/auth/logout">
        <button class="btn-link">Sign out</button>
      </form>
    </nav>
    {% endif %}
  </header>

  <main class="main-content {% block mainClass %}{% endblock %}">
    {% block content %}{% endblock %}
  </main>

  {% block scripts %}{% endblock %}
</body>
</html>
